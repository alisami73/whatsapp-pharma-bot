# ============================================================================
# WhatsApp Pharma Bot - Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs.
# ============================================================================

# Port local (non utilisé sur Vercel)
PORT=3000

# ── Twilio ──────────────────────────────────────────────────────────────────

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stratégie d'envoi : utilisez l'un des deux blocs ci-dessous.
# Option 1 : Messaging Service (recommandé pour production)
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2 : Numéro WhatsApp direct (sandbox Twilio : +14155238886)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# URL publique HTTPS de votre déploiement (pour les status callbacks Twilio)
# Ex: https://votre-projet.vercel.app  ou  https://votre-domaine.com
PUBLIC_BASE_URL=

# Override optionnel pour l'URL de status callback
TWILIO_STATUS_CALLBACK_URL=

# true = autoriser l'envoi admin sans opt-in préalable (tests uniquement)
TWILIO_ALLOW_MANUAL_SEND_WITHOUT_CONSENT=false

# ── MedIndex API ─────────────────────────────────────────────────────────────
# Si non défini, une base locale de démonstration est utilisée.

MEDINDEX_API_URL=
MEDINDEX_API_KEY=
MEDINDEX_TIMEOUT_MS=8000

# ── Blink Pharma ─────────────────────────────────────────────────────────────
# Si non défini, des données de démonstration sont retournées.

BLINK_API_URL=
BLINK_API_KEY=

# ── Sobrus ───────────────────────────────────────────────────────────────────
# Si non défini, des données de démonstration sont retournées.

SOBRUS_API_URL=
SOBRUS_API_KEY=

# Timeout commun pour les connecteurs de monitoring (ms)
MONITORING_TIMEOUT_MS=10000

# ── Sécurité Admin ───────────────────────────────────────────────────────────
# Mot de passe HTTP Basic pour protéger /admin/*.
# Login : admin  |  Mot de passe : valeur ci-dessous.
# Si non défini, l'admin est accessible sans authentification (dev local uniquement).
ADMIN_SECRET=
