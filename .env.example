# ============================================================================
# WhatsApp Pharma Bot - Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs.
# ============================================================================

# ── Supabase pgvector (RAG production) ───────────────────────────────────────
# Projet : https://supabase.com/dashboard/project/<your-project-id>
# Exécutez scripts/supabase_schema.sql dans l'éditeur SQL Supabase d'abord.
# Utilisez la Service Role Key (Settings > API) — le bot tourne côté serveur.

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Port local (non utilisé sur Vercel)
PORT=3000

# ── Twilio ──────────────────────────────────────────────────────────────────

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stratégie d'envoi : utilisez l'un des deux blocs ci-dessous.
# Option 1 : Messaging Service (recommandé pour production)
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2 : Numéro WhatsApp direct (numéro WhatsApp Blink : +212768782598)
TWILIO_WHATSAPP_FROM=whatsapp:+212768782598

# Content SID du WhatsApp Flow d'onboarding 3 écrans (consentement, rôle, accueil)
TWILIO_ONBOARDING_FLOW_CONTENT_SID=

# URL publique HTTPS de votre déploiement (pour les status callbacks Twilio)
# Ex: https://votre-projet.vercel.app  ou  https://votre-domaine.com
PUBLIC_BASE_URL=

# Override optionnel pour l'URL de status callback
TWILIO_STATUS_CALLBACK_URL=

# true = autoriser l'envoi admin sans opt-in préalable (tests uniquement)
TWILIO_ALLOW_MANUAL_SEND_WITHOUT_CONSENT=false

# ── Formulaire de contact / email ───────────────────────────────────────────
# Railway Free/Trial/Hobby ne permet pas SMTP sortant.
# Solution recommandée sur Railway : Microsoft Graph (HTTPS) ou un provider email API.
# Si vous gardez SMTP, Railway Pro+ est requis.
#
# Option 1 - Microsoft Graph (recommandé sur Railway)
# CONTACT_EMAIL_PROVIDER=msgraph
# CONTACT_GRAPH_TENANT_ID=<tenant-id>
# CONTACT_GRAPH_CLIENT_ID=<client-id>
# CONTACT_GRAPH_CLIENT_SECRET=<client-secret>
# CONTACT_GRAPH_USER=contact@blinkpharma.ma
#
# Option 2 - SMTP Microsoft 365 / Office 365
# CONTACT_SMTP_HOST=smtp.office365.com
# CONTACT_SMTP_PORT=587
# CONTACT_SMTP_SECURE=false
# CONTACT_SMTP_REQUIRE_TLS=true
# CONTACT_SMTP_USER=contact@blinkpharma.ma
# CONTACT_SMTP_PASS=<mot-de-passe-ou-app-password>
# CONTACT_FORM_TO=contact@blinkpharma.ma
# CONTACT_FORM_FROM="Blink Pharma <contact@blinkpharma.ma>"

CONTACT_FORM_TO=contact@blinkpharma.ma
CONTACT_FORM_FROM="Blink Pharma <contact@blinkpharma.ma>"
CONTACT_EMAIL_PROVIDER=
CONTACT_GRAPH_TENANT_ID=
CONTACT_GRAPH_CLIENT_ID=
CONTACT_GRAPH_CLIENT_SECRET=
CONTACT_GRAPH_USER=
CONTACT_GRAPH_TIMEOUT_MS=15000
CONTACT_SMTP_URL=
CONTACT_SMTP_HOST=
CONTACT_SMTP_PORT=
CONTACT_SMTP_SECURE=false
CONTACT_SMTP_REQUIRE_TLS=false
CONTACT_SMTP_USER=
CONTACT_SMTP_PASS=
CONTACT_SMTP_TIMEOUT_MS=15000

# ── MedIndex API ─────────────────────────────────────────────────────────────
# Si non défini, une base locale de démonstration est utilisée.

MEDINDEX_API_URL=
MEDINDEX_API_KEY=
MEDINDEX_TIMEOUT_MS=8000

# ── Blink Pharma ─────────────────────────────────────────────────────────────
# Si non défini, des données de démonstration sont retournées.

BLINK_API_URL=
BLINK_API_KEY=

# ── Sobrus ───────────────────────────────────────────────────────────────────
# Si non défini, des données de démonstration sont retournées.

SOBRUS_API_URL=
SOBRUS_API_KEY=

# Timeout commun pour les connecteurs de monitoring (ms)
MONITORING_TIMEOUT_MS=10000

# ── Sécurité Admin ───────────────────────────────────────────────────────────
# Mot de passe HTTP Basic pour protéger /admin/*.
# Login : admin  |  Mot de passe : valeur ci-dessous.
# Si non défini, l'admin est accessible sans authentification (dev local uniquement).
ADMIN_SECRET=

# ── PDF OCR Premium / RAG Python Pipeline ───────────────────────────────────

AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_MODEL=prebuilt-layout
AZURE_DOCUMENT_FALLBACK_MODEL=prebuilt-read

AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=rag-documents
AZURE_BLOB_PREFIX=ocr-ingestion

OCR_LOW_THRESHOLD=0.55
CHUNK_SIZE=320
CHUNK_OVERLAP=40
TOP_K=4

EMBEDDING_PROVIDER=azure_openai
VECTOR_STORE_PROVIDER=json
VECTOR_STORE_PATH=data/legal_kb/indexes/azure_ocr_pipeline_index.json
LOW_OCR_JOURNAL_PATH=data/legal_kb/audit/low_ocr_journal.jsonl
PIPELINE_MAX_RETRIES=2
LOG_LEVEL=INFO

# Azure AI Search (activez avec VECTOR_STORE_PROVIDER=azure_ai_search)
AZURE_SEARCH_ENDPOINT=
# Utilisez une admin key pour créer/upsert l'index; une query key suffit pour search-only.
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=legal-rag-chunks
AZURE_SEARCH_API_VERSION=2025-09-01
AZURE_SEARCH_BATCH_SIZE=100
AZURE_SEARCH_ENABLE_HYBRID=true

# Prévu pour activation ultérieure du reranking sémantique Azure AI Search.
# L'index doit disposer d'une semantic configuration compatible avant activation.
AZURE_SEARCH_ENABLE_SEMANTIC_RERANKER=false
AZURE_SEARCH_SEMANTIC_CONFIGURATION=

# Azure OpenAI embeddings pour le pipeline Python
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Optionnel si vous préférez OpenAI direct au lieu d'Azure OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=

# Optionnel: emplacement du cache Swift pour l'extracteur PDF natif
SWIFT_MODULE_CACHE_PATH=/tmp/swift-module-cache
